# Copy to .env and fill in. None of this is required for `make generate-cached`.

# Needed for live generation (SDK fallback and MCP paths):
ANTHROPIC_API_KEY=

# --- SmartBear MCP server (the headline path) ---
# @smartbear/mcp is MIT-licensed and free to use with the self-hosted Pact Broker.
# Start the broker first:  docker compose --profile broker up -d
#
# These vars are read by .mcp.json (MCP server) and by the publish/verify targets:
PACT_BROKER_BASE_URL=http://localhost:9292
PACT_BROKER_USERNAME=pact
PACT_BROKER_PASSWORD=pact
